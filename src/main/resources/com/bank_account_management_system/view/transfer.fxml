<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefWidth="400" spacing="15" style="-fx-background-color: #0D2F66; -fx-background-radius: 0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bank_account_management_system.controller.TransferController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <!-- TITLE -->
    <Label style="-fx-text-fill:white; -fx-font-size:20; -fx-font-weight:bold;" text="Transfer Money" />

    <!-- FROM ACCOUNT -->
    <TextField fx:id="fromAccountId" promptText="Select From Account" />

    <!-- TO ACCOUNT -->
    <TextField fx:id="toAccountId" promptText="Select To Account" />

    <!--  TO ACCOUNT TYPE  -->
    <ComboBox fx:id="toAccountTypeBox" promptText="Recipient Account Type" prefWidth="200"/>
    <!-- AMOUNT -->
    <TextField fx:id="amountField" promptText="Enter Amount" style="-fx-background-radius:8;" />

    <!-- ERROR MESSAGE -->
    <Label fx:id="errorLabel" style="-fx-text-fill:red;" text="" />

    <!-- BUTTONS -->
    <HBox alignment="CENTER" spacing="15">

        <Button onAction="#handleTransfer" prefWidth="120" style="-fx-background-color:#7C3AED; -fx-text-fill:white;" text="Transfer" />

        <Button fx:id="cancelBtn" onAction="#handleCancel" prefWidth="120" style="-fx-background-color:#DC2626; -fx-text-fill:white;" text="Cancel" />

    </HBox>

</VBox>
